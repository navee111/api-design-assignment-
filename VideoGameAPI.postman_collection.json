			"name": "Authentication",
			"item": [
				{
					"name": "Register User - Success",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has token\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.register.token).to.be.a('string');",
									"    pm.environment.set(\"authToken\", jsonData.data.register.token);",
									"});",
									"",
									"pm.test(\"User created with correct email\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.data.register.user.email).to.eql(\"test@example.com\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "graphql",
							"graphql": {
								"query": "mutation {\n  register(\n    email: \"test@example.com\"\n    password: \"password123\"\n    name: \"Test User\"\n  ) {\n    token\n    user {\n      id\n      email\n      name\n    }\n  }\n}",
								"variables": ""
							}
						},
						"url": {
							"raw": "{{baseUrl}}/graphql",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"graphql"
							]
						}
					},
					"response": []
				},
